[Unit]
Description=Run Fula Discovery heartbeat every minute
Requires=relay-heartbeat.service

[Timer]
# Fire 1 minute after boot, then every minute. AccuracySec=10s tightens
# scheduling so heartbeats land predictably within their freshness window.
OnBootSec=1min
OnUnitActiveSec=1min
AccuracySec=10s
Persistent=true

[Install]
WantedBy=timers.target
