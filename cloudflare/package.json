    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "@noble/ed25519": "^2.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.0.0"
  }
}
